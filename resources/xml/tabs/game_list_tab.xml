<brls:Box
    width="auto"
    height="auto"
    axis="column">

    <brls:Box
        width="auto"
        height="auto"
        justifyContent="center"
        margin="10"
        axis="row">
        <brls:ProgressSpinner
            width="30"
            height="30"
            id="loading_spinner"
            margin="10"
            size="normal"/>
        <brls:Label
            width="auto"
            height="30"
            id="loading_label"
            margin="10"/>
    </brls:Box>

    <brls:RecyclerFrame
        id="recycler"
        width="auto"
        height="auto"
        grow="1.0"
        paddingTop="@style/brls/sidebar/padding_top"
        paddingRight="@style/brls/sidebar/padding_right"
        paddingBottom="@style/brls/sidebar/padding_bottom"
        paddingLeft="@style/brls/sidebar/padding_left"/>

</brls:Box>
